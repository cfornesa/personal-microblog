{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "build:web:clean": "rm -rf artifacts/microblog/dist && npm run build --workspace=@workspace/microblog",
    "dev": "npm run dev --workspace=@workspace/api-server",
    "dev:api": "npm run dev --workspace=@workspace/api-server",
    "dev:web": "npm run dev --workspace=@workspace/microblog",
    "start": "npm run start --workspace=@workspace/api-server",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present"
  },
  "private": true,
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "overrides": {
    "@esbuild-kit/esm-loader": "npm:tsx@^4.21.0",
    "esbuild": "0.27.3"
  }
}
