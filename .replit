modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "--enable-source-maps", "artifacts/api-server/dist/index.mjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8090
externalPort = 3001

[[ports]]
localPort = 9098
externalPort = 3003

[[ports]]
localPort = 9099
externalPort = 4200

[[ports]]
localPort = 20925
externalPort = 3000

