# Server
# Local default only. Do not set PORT in Replit Secrets unless Replit explicitly
# requires it; Replit workspace/deployment runtimes provide their own PORT.
PORT=8080
ALLOWED_ORIGINS=http://localhost:8080

# Optional two-port hot dev server
FRONTEND_PORT=3000
API_ORIGIN=http://localhost:8080

# Current backend auth (Auth.js)
AUTH_SECRET=replace_with_a_long_random_secret
GITHUB_ID=your_github_oauth_app_client_id
GITHUB_SECRET=your_github_oauth_app_client_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Database
# Point both local and deployed runtimes at the canonical MySQL database.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# AI writing assistant
# 32-byte secret used to encrypt user-saved AI API keys at rest (also used for platform tokens).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_SETTINGS_ENCRYPTION_KEY=replace_with_a_32_byte_base64_secret

# POSSE outbound syndication — platform OAuth credentials
# Register your app with each platform's developer console and set the redirect URI to:
#   {your-origin}/api/platform-oauth/{platform}/callback

# WordPress.com OAuth — https://developer.wordpress.com/apps/
WORDPRESS_COM_CLIENT_ID=
WORDPRESS_COM_CLIENT_SECRET=

# Blogger (separate Google OAuth app, scope: https://www.googleapis.com/auth/blogger)
# Create at https://console.cloud.google.com/ — separate from the sign-in Google app
BLOGGER_GOOGLE_CLIENT_ID=
BLOGGER_GOOGLE_CLIENT_SECRET=

# Site identity — used in feed metadata, Open Graph tags, and AI headers.
# Set PUBLIC_SITE_URL to your canonical public URL to ensure all feed links
# and social meta tags always point to the right origin regardless of proxy.
# PUBLIC_SITE_URL=https://your-domain.com
# SITE_TITLE=My Microblog
# SITE_DESCRIPTION=A personal microblog.
# SITE_AUTHOR_NAME=Your Name

# Optional
# DB_SSL=false
# SQLITE_IMPORT_PATH=./data/microblog.db
# LOG_LEVEL=info
