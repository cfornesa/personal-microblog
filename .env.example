# Server
# Local default only. Do not set PORT in Replit Secrets unless Replit explicitly
# requires it; Replit workspace/deployment runtimes provide their own PORT.
PORT=8080
ALLOWED_ORIGINS=http://localhost:8080

# Optional two-port hot dev server
FRONTEND_PORT=3000
API_ORIGIN=http://localhost:8080

# Current backend auth (Auth.js)
AUTH_SECRET=replace_with_a_long_random_secret
GITHUB_ID=your_github_oauth_app_client_id
GITHUB_SECRET=your_github_oauth_app_client_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Database
# Point both local and deployed runtimes at the canonical MySQL database.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# AI writing assistant
# 32-byte secret used to encrypt user-saved AI API keys at rest.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_SETTINGS_ENCRYPTION_KEY=replace_with_a_32_byte_base64_secret

# Site identity — used in feed metadata, Open Graph tags, and AI headers.
# Set PUBLIC_SITE_URL to your canonical public URL to ensure all feed links
# and social meta tags always point to the right origin regardless of proxy.
# PUBLIC_SITE_URL=https://your-domain.com
# SITE_TITLE=My Microblog
# SITE_DESCRIPTION=A personal microblog.
# SITE_AUTHOR_NAME=Your Name

# Optional
# DB_SSL=false
# SQLITE_IMPORT_PATH=./data/microblog.db
# LOG_LEVEL=info
