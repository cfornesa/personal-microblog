# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:20925,http://localhost:3000,http://localhost:8080

# Frontend dev server
FRONTEND_PORT=3000
API_ORIGIN=http://localhost:8080

# Current backend auth (Auth.js)
AUTH_SECRET=replace_with_a_long_random_secret
AUTH_URL=http://localhost:3000
GITHUB_ID=your_github_oauth_app_client_id
GITHUB_SECRET=your_github_oauth_app_client_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Database
# Production: set DATABASE_URL to your remote libsql/Turso connection string.
# Local development: omit DATABASE_URL and use DATABASE_PATH if you want a custom SQLite file location.
DATABASE_URL=

# Optional local override
# DATABASE_PATH=./data/microblog.db
# LOG_LEVEL=info
